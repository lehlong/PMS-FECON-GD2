                </a>
            </li>
            <li class="gantt-menu-item gantt-menu-item-last">
                <a data-action="expandAll">
                    <span class="material-icons">keyboard_arrow_down</span>Mở rộng
                </a>
            </li>
            <li class="gantt-menu-item gantt-menu-item-last">
