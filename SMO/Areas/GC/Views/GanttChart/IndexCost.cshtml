    <script type="text/javascript" src="~/Scripts/GanttChart/nav_menu.js?v=7.1.7"></script>
    <script type="text/javascript" src="~/Scripts/GanttChart/zoom.js?v=7.1.7"></script>

    <div class="gantt-demo-header">
